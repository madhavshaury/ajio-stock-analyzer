# Copy to `.env` and fill in real values. Never commit `.env`.

# --- Redash (api_event_log queries) ---
REDASH_URL=https://redash.example.com
REDASH_API_KEY=
REDASH_DATA_SOURCE_ID=

# --- ERPNext (Phase 2: stock + open PO lookup) ---
# Site root only (https://your-site.com). Do not use a Desk URL with /app — API is at /api/...
ERPNEXT_URL=https://erp.example.com
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
# Optional: for “Test ERPNext API” single-document GET (same as curl …/Purchase Order/<name>)
ERPNEXT_TEST_PO=
